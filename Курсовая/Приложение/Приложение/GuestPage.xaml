<Page x:Class="Приложение.GuestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Приложение"
      xmlns:converters="clr-namespace:Приложение.Converters"
      mc:Ignorable="d" 
      Title="GuestPage" 
      Loaded="Page_Loaded">

    <Page.Resources>
        <converters:DiscountToVisibilityConverter x:Key="DiscountToVisibilityConverter"/>
        <converters:NoDiscountToVisibilityConverter x:Key="NoDiscountToVisibilityConverter"/>
        <converters:BackgroundColorConverter x:Key="BackgroundColorConverter"/>
        <converters:TextColorConverter x:Key="TextColorConverter"/>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
            <TextBlock x:Name="txtRole" Text="Гость" FontSize="14" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </WrapPanel>

        <Button Grid.Row="0" x:Name="btnCancel" Content="Назад" Width="80" Height="30" HorizontalAlignment="Right"
                Margin="0,10,20,10" BorderThickness="1.5" Click="btnCancek_Click"/>

        <ListBox Grid.Row="1" x:Name="productsList" d:ItemsSource="{d:SampleData ItemCount=1}"
                 Margin="10,0,10,10" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2" CornerRadius="9" 
                            Padding="5" Margin="5" 
                            Background="{Binding Converter={StaticResource BackgroundColorConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2" 
                                    Margin="5" Width="150" Height="150"
                                    Background="White">
                                <Image Source="{Binding ImagePath}" Stretch="Fill" Width="150" Height="150"/>
                            </Border>

                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" 
                                    Padding="5" Margin="5"
                                    Background="White">
                                <StackPanel>
                                    <WrapPanel>
                                        <TextBlock Text="{Binding Category}" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text=" | " FontSize="14" FontWeight="Bold" Foreground="#2C2C2C"/>
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                                   TextWrapping="Wrap" Foreground="#2C2C2C"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Описание: " FontSize="16"/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" 
                                                   MaxWidth="500" FontSize="16" Foreground="#2C2C2C"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Производитель: " FontSize="16" Foreground="#2C2C2C"/>
                                        <TextBlock Text="{Binding Manufacturer}" FontSize="16" Foreground="#2C2C2C"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Поставщик: " FontSize="16" Foreground="#2C2C2C"/>
                                        <TextBlock Text="{Binding Supplier}" FontSize="16"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Цена: " FontSize="16"/>

                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}" 
                                                   FontSize="16" Foreground="#E74C3C"
                                                   TextDecorations="Strikethrough" Margin="0,0,10,0"
                                                   Visibility="{Binding Discount, Converter={StaticResource DiscountToVisibilityConverter}}"/>

                                        <TextBlock Text="{Binding PriceWithDiscount, StringFormat={}{0:N2}}" 
                                                   FontSize="16" FontWeight="Bold" Foreground="Black" 
                                                   Visibility="{Binding Discount, Converter={StaticResource DiscountToVisibilityConverter}}"/>

                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}" 
                                                   FontSize="16" Foreground="Black" 
                                                   Visibility="{Binding Discount, Converter={StaticResource NoDiscountToVisibilityConverter}}"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Единица измерения: " FontSize="16" />
                                        <TextBlock Text="{Binding Unit}" FontSize="16"/>
                                    </WrapPanel>

                                    <WrapPanel>
                                        <TextBlock Text="Количество на складе: " FontSize="16"/>
                                        <TextBlock Text="{Binding Quantity}" FontSize="16"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="2" 
                                    Margin="5" Width="150" Height="150"
                                    Background="White">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <WrapPanel>
                                        <TextBlock Text="Скидка: " FontSize="14"/>
                                        <TextBlock Text="{Binding Discount}" FontSize="20" FontWeight="Bold"/>
                                        <TextBlock Text="%" FontSize="14"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>