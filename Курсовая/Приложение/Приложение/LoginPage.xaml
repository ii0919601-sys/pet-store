<Page x:Class="Приложение.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Приложение"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1200"
      Title="LoginPage">

    <Grid Background="White">

        <Border Width="500" Height="500" BorderThickness="2" CornerRadius="10" 
                BorderBrush="Black">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Войти" FontSize="24" FontWeight="Bold"/>
                </WrapPanel>

                <Border BorderBrush="#4A5C6E" BorderThickness="1.5" CornerRadius="5" 
                        Height="40" Background="Transparent">
                    <TextBox x:Name="LoginTextBox" BorderThickness="0" VerticalAlignment="Center" FontSize="16" 
                             Margin="10,0,0,0" Text="Логин" GotFocus="LoginTextBox_GotFocus" 
                             LostFocus="LoginTextBox_LostFocus" />
                </Border>
     
                <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="5" Height="40"
                       Margin="0,15,0,0" >
                    <Grid>
                        <PasswordBox x:Name="PassLogin" BorderThickness="0" GotFocus="PassLogin_GotFocus"
                                     LostFocus="PassLogin_LostFocus" VerticalAlignment="Center" FontSize="16" 
                                     Margin="10,0,0,0"/>
                        <TextBlock x:Name="PassPlaceholder" Text="Пароль" VerticalAlignment="Center"
                                   FontSize="16" Margin="10,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <Button x:Name="SignInButton" Content="Войти" FontSize="16"
                        Height="40" Margin="0,25,0,0" Click="SignInButton_Click"
                         Foreground="#1E2A36"
                        BorderThickness="1" FontWeight="Bold"/>

                <Button x:Name="SignGuestButton" Content="Войти как гость" FontSize="14"
                        Height="40" Margin="0,10,0,0" Click="SignGuestButton_Click"
                         BorderThickness="1"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>