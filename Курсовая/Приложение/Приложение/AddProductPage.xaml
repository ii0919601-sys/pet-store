<Page x:Class="Приложение.AddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Приложение"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1200"
      Title="AddProductPage">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="1" CornerRadius="15" BorderBrush="Black" 
                BorderThickness="2" Height="550" Width="600"
                Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Добавить товар" FontSize="25" FontWeight="Bold"
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                    <StackPanel Margin="0,0,10,0">
                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Артикул товара:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="ArticleTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Наименование:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="NameTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Цена:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="PriceTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Количество:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="QuantityTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Поставщик:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="SupplierTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Производитель:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ManufacturerComboBox" Width="300" Height="28" 
                                      Background="White" BorderBrush="#B0C4DE" BorderThickness="1"
                                      SelectionChanged="ManufacturerTextBox_SelectionChanged"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Категория:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CategoryComboBox" Width="300" Height="28" 
                                      Background="White" BorderBrush="#B0C4DE" BorderThickness="1"
                                      SelectionChanged="CategoryTextBox_SelectionChanged"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Описание:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Top" Margin="0,5,0,0"/>
                            <TextBox x:Name="DescriptionTextBox" Width="300" Height="70" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Единица изм.:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmdUnit" Width="300" Height="28" 
                                      Background="White" BorderBrush="#B0C4DE" BorderThickness="1">
                                <ComboBoxItem Content="Шт."/>
                                <ComboBoxItem Content="Кг."/>
                                <ComboBoxItem Content="Граммы"/>
                                <ComboBoxItem Content="Литры"/>
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Фото:" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="PhotoPathTextBox" Width="200" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                            <Button x:Name="PhotoPath" Content="Обзор" Width="70" Height="28" Margin="5,0,0,0"
                                    Background="#B5D1E8" Foreground="#2C3E50" BorderBrush="#2C3E50"
                                    BorderThickness="1" Click="SelectImageButton_Click"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,5">
                            <TextBlock Text="Скидка (%):" FontSize="14" Foreground="#2C3E50" 
                                       Width="130" VerticalAlignment="Center"/>
                            <TextBox x:Name="DiscountTextBox" Width="300" Height="28" 
                                     Background="White" BorderBrush="#B0C4DE" BorderThickness="1"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
                
                <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="30" 
                            Margin="5"
                            BorderThickness="1" Click="SaveButton_Click"/>
                    <Button x:Name="CancelButton" Content="Назад" Width="100" Height="30" 
                            Margin="5" BorderThickness="1" Click="CancelButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>